# Cloudflare Pages – Environment Variable Example
#
# Copy or rename this file to ".env" and fill in your own values, then use it
# as a reference when setting environment variables in the Cloudflare Pages
# dashboard (Settings > Environment Variables).
#
# DO NOT commit a filled-in .env file – the .gitignore already excludes ".env".
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW WSQS_ VARIABLES WORK
# ─────────────────────────────────────────────────────────────────────────────
# Every variable that starts with WSQS_ is automatically converted into a URL
# query-string parameter when the page loads. The WSQS_ prefix is stripped, and
# each remaining underscore (_) becomes a hyphen (-) in the query key.
#
#   WSQS_latLonQuery=Orlando ...
#   → ?latLonQuery=Orlando+...
#
#   WSQS_hazards_checkbox=false
#   → &hazards-checkbox=false
#
# This lets you "bake" an entire permalink into the static deployment so that
# every visitor automatically lands on the correct city and display settings
# without having to touch the URL.
#
# Generate a starting point by clicking "Copy Permalink" in the WeatherStar
# settings panel, then convert each key as described above.
# ─────────────────────────────────────────────────────────────────────────────

# ── LOCATION (required for a static/kiosk deployment) ────────────────────────
# Plain-text address or airport name – the app geocodes it automatically.
WSQS_latLonQuery=Orlando International Airport, Orlando, FL, USA

# Optional: pre-supply the resolved lat/lon to skip geocoding entirely.
# Use the permalink to capture this value after selecting a location in the UI.
# WSQS_latLon={"lat":28.431,"lon":-81.3076}

# ── DISPLAY SECTIONS ─────────────────────────────────────────────────────────
# Set each section to "true" (show) or "false" (hide).
WSQS_hazards_checkbox=true
WSQS_current_weather_checkbox=true
WSQS_latest_observations_checkbox=true
WSQS_hourly_checkbox=false
WSQS_hourly_graph_checkbox=true
WSQS_travel_checkbox=false
WSQS_regional_forecast_checkbox=true
WSQS_local_forecast_checkbox=true
WSQS_extended_forecast_checkbox=true
WSQS_almanac_checkbox=false
WSQS_spc_outlook_checkbox=true
WSQS_radar_checkbox=true

# ── PLAYBACK & APPEARANCE ────────────────────────────────────────────────────
# Speed multiplier: 0.5 (very slow) · 0.75 (slow) · 1.00 (normal) · 1.25 (fast) · 1.50 (very fast)
WSQS_settings_speed_select=1.00

# Units: "us" (°F, mph, in) or "metric" (°C, km/h, mm)
WSQS_settings_units_select=us

# Widescreen (16:9 stretch): true | false
WSQS_settings_wide_checkbox=false

# Scan lines retro effect: true | false
WSQS_settings_scanLines_checkbox=false

# ── KIOSK / DIGITAL SIGNAGE ──────────────────────────────────────────────────
# kiosk=true hides all controls and starts playing immediately.
# Combine with a browser launched with --kiosk for true fullscreen signage.
WSQS_settings_kiosk_checkbox=false

# Auto-start music playback (subject to browser autoplay policy).
# WSQS_settings_mediaPlaying_boolean=true
